<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane styleClass="main-menu"
           xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.oop.payday.controller.LobbyController">
    <children>
        <VBox alignment="TOP_CENTER" spacing="22.0" styleClass="menu-card" maxWidth="900.0" maxHeight="-Infinity">
            <children>
                <VBox alignment="CENTER" spacing="4.0">
                    <children>
                        <Label styleClass="title" text="대기실" />
                        <Label fx:id="roomAddressLabel" styleClass="subtitle" />
                    </children>
                </VBox>

                <Region styleClass="menu-divider" maxWidth="Infinity" />

                <CheckBox fx:id="practiceCheck" text="연습 모드 (20코인 · 리더 효과 비활성)" />

                <HBox spacing="28.0" alignment="TOP_CENTER">
                    <children>
                        <VBox fx:id="teamABox" spacing="10.0" styleClass="lobby-team"
                              minWidth="380.0" prefWidth="380.0" maxWidth="380.0" />
                        <VBox fx:id="teamBBox" spacing="10.0" styleClass="lobby-team"
                              minWidth="380.0" prefWidth="380.0" maxWidth="380.0" />
                    </children>
                </HBox>

                <Region styleClass="menu-divider" maxWidth="Infinity" />

                <HBox spacing="14.0" alignment="CENTER">
                    <children>
                        <Button text="뒤로" styleClass="menu-button" onAction="#onBack" />
                        <Button fx:id="startButton" text="게임 시작" styleClass="menu-mode-button" onAction="#onStart" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</StackPane>
