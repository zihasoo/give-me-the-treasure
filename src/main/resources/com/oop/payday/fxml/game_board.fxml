<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane styleClass="board"
           xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.oop.payday.controller.GameBoardController">
    <children>
        <BorderPane>
            <left>
                <VBox styleClass="left-sidebar" spacing="10.0">
                    <children>
                        <VBox styleClass="info-card opponent-card" spacing="6.0">
                            <children>
                                <Label fx:id="fieldBTitleLabel" styleClass="info-card-title" wrapText="true" />
                                <Region styleClass="info-divider" />
                                <VBox fx:id="fieldBHelperFlow" styleClass="sidebar-helper-flow" spacing="6.0" />
                                <Region styleClass="info-divider" />
                                <VBox styleClass="officer-portrait" spacing="3.0">
                                    <children>
                                        <Label fx:id="fieldBOfficerLabel" styleClass="officer-name" wrapText="true" />
                                        <Label fx:id="fieldBOfficerEffectLabel" styleClass="officer-effect" wrapText="true" />
                                    </children>
                                </VBox>
                                <Label fx:id="fieldBCoinsLabel" styleClass="info-coins" maxWidth="Infinity" />
                            </children>
                        </VBox>

                        <Region VBox.vgrow="ALWAYS" />
                        <Region styleClass="sidebar-mid-divider" />
                        <Region VBox.vgrow="ALWAYS" />

                        <VBox styleClass="info-card mine-card" spacing="6.0">
                            <children>
                                <Label fx:id="fieldACoinsLabel" styleClass="info-coins" maxWidth="Infinity" />
                                <VBox styleClass="officer-portrait" spacing="3.0">
                                    <children>
                                        <Label fx:id="fieldAOfficerLabel" styleClass="officer-name" wrapText="true" />
                                        <Label fx:id="fieldAOfficerEffectLabel" styleClass="officer-effect" wrapText="true" />
                                    </children>
                                </VBox>
                                <Region styleClass="info-divider" />
                                <VBox fx:id="fieldAHelperFlow" styleClass="sidebar-helper-flow" spacing="6.0" />
                                <Region styleClass="info-divider" />
                                <Label fx:id="fieldATitleLabel" styleClass="info-card-title" wrapText="true" />
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </left>
            <center>
                <VBox styleClass="board-center" spacing="8.0">
                    <children>
                        <StackPane fx:id="fieldBStage" styleClass="center-field-stage opponent-field-stage"
                                   minHeight="168.0" prefHeight="168.0" maxHeight="168.0" maxWidth="Infinity">
                            <children>
                                <FlowPane fx:id="fieldBFlow" alignment="CENTER" hgap="8.0" vgap="8.0" maxWidth="Infinity" />
                                <Label fx:id="fieldBCountLabel" styleClass="field-count-label" StackPane.alignment="TOP_RIGHT">
                                    <StackPane.margin>
                                        <Insets top="6.0" right="10.0" />
                                    </StackPane.margin>
                                </Label>
                            </children>
                        </StackPane>

                        <StackPane fx:id="centerArea" VBox.vgrow="ALWAYS" minHeight="0.0" styleClass="center-area">
                            <children>
                                <StackPane fx:id="contentArea" minHeight="0.0" alignment="CENTER" />
                                <StackPane fx:id="overlayArea" minHeight="0.0" mouseTransparent="true" />
                            </children>
                        </StackPane>

                        <StackPane fx:id="fieldAStage" styleClass="center-field-stage mine-field-stage"
                                   minHeight="168.0" prefHeight="168.0" maxHeight="168.0" maxWidth="Infinity">
                            <children>
                                <FlowPane fx:id="fieldAFlow" alignment="CENTER" hgap="8.0" vgap="8.0" maxWidth="Infinity" />
                                <Label fx:id="fieldACountLabel" styleClass="field-count-label" StackPane.alignment="TOP_RIGHT">
                                    <StackPane.margin>
                                        <Insets top="6.0" right="10.0" />
                                    </StackPane.margin>
                                </Label>
                            </children>
                        </StackPane>

                        <HBox styleClass="center-status-bar" spacing="14.0" alignment="CENTER_LEFT">
                            <children>
                                <Label fx:id="turnLabel" styleClass="turn" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Label fx:id="messageLabel" styleClass="message" maxWidth="620.0" />
                                <Button styleClass="score-table-button" text="조합표" onAction="#onScoreTable" />
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </center>
        </BorderPane>

        <Pane fx:id="globalOverlay" mouseTransparent="true" pickOnBounds="false" />
        <!-- screenOverlay(메뉴·게임오버·규칙서)는 globalOverlay(연출)보다 위에 둬, 연출 중에도 항상
             메뉴가 위에 뜨고 클릭이 막히지 않게 한다. 평소엔 비어있고 mouseTransparent라 연출에 영향 없음. -->
        <StackPane fx:id="screenOverlay" mouseTransparent="true" pickOnBounds="false" />
    </children>
</StackPane>
