<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="20.0" styleClass="main-menu"
      xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.oop.payday.controller.MainMenuController">
    <children>
        <Label styleClass="title" text="도적단의 월급날" />
        <Label styleClass="subtitle" text="Give Me The Treasure" />
        <Button fx:id="pvpButton" prefWidth="220.0" styleClass="menu-button"
                text="사람 vs 사람" onAction="#onPlayerVsPlayer" />
        <Button fx:id="pvbButton" prefWidth="220.0" styleClass="menu-button"
                text="사람 vs 봇" onAction="#onPlayerVsBot" />
        <CheckBox fx:id="practiceRuleCheck" text="연습 룰 (20코인 승리 · 리더 효과 비활성)" />
        <Label fx:id="statusLabel" styleClass="status" />
    </children>
</VBox>
