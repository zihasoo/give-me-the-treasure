<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane styleClass="main-menu"
           xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.oop.payday.controller.MainMenuController">
    <children>
        <VBox alignment="TOP_CENTER" spacing="20.0" styleClass="menu-card" maxWidth="460.0" maxHeight="-Infinity">
            <children>
                <VBox alignment="CENTER" spacing="2.0">
                    <children>
                        <Label styleClass="menu-emblem" text="◈" />
                        <Label styleClass="title" text="도적단의 월급날" />
                        <Label styleClass="subtitle" text="Give Me The Treasure" />
                    </children>
                </VBox>

                <Region styleClass="menu-divider" maxWidth="Infinity" />

                <HBox alignment="CENTER_LEFT" spacing="10.0">
                    <children>
                        <Label styleClass="menu-section" text="닉네임" minWidth="50.0" />
                        <TextField fx:id="nicknameField" styleClass="menu-text-field"
                                   promptText="이름을 입력하세요" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
                    </children>
                </HBox>

                <Region styleClass="menu-divider" maxWidth="Infinity" />

                <VBox alignment="CENTER" spacing="10.0">
                    <children>
                        <Label styleClass="menu-section" text="게임 모드" />
                        <Button maxWidth="Infinity" styleClass="menu-mode-button"
                                text="게임 시작" onAction="#onStartGame" />
                        <Button maxWidth="Infinity" styleClass="menu-mode-button"
                                text="접속하기" onAction="#onJoinGame" />
                        <Button maxWidth="Infinity" styleClass="menu-mode-button"
                                text="LLM 봇과 1v1" onAction="#onLlmGame" />
                    </children>
                </VBox>

                <Region styleClass="menu-divider" maxWidth="Infinity" />

                <Button styleClass="score-table-button" text="조합표" onAction="#onScoreTable" maxWidth="Infinity" />
                <Button styleClass="score-table-button" text="규칙서" onAction="#onRulebook" maxWidth="Infinity" />
            </children>
        </VBox>

        <StackPane fx:id="menuOverlay" mouseTransparent="true" pickOnBounds="false" />
    </children>
</StackPane>
